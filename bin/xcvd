#!/usr/bin/env python3

import argparse
import json
import os
import platform
import subprocess
import sys
import tempfile
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer


class ClipboardError(Exception):
    pass


class NoImageError(ClipboardError):
    pass


def detect_backend():
    system = platform.system()
    if system == "Darwin":
      return "macos" if shutil_which("pngpaste") else None

    if os.environ.get("WAYLAND_DISPLAY") or os.environ.get("XDG_SESSION_TYPE") == "wayland":
        if shutil_which("wl-paste"):
            return "wayland"

    if os.environ.get("DISPLAY") and shutil_which("xclip"):
        return "x11"

    if shutil_which("wl-paste"):
        return "wayland"

    if shutil_which("xclip"):
        return "x11"

    return None


def shutil_which(name):
    for path in os.environ.get("PATH", "").split(os.pathsep):
        candidate = os.path.join(path, name)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def read_png_from_macos():
    fd, path = tempfile.mkstemp(prefix="xcv-", suffix=".png")
    os.close(fd)
    try:
        result = subprocess.run(
            ["pngpaste", path],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            check=False,
        )
        if result.returncode != 0 or not os.path.exists(path) or os.path.getsize(path) == 0:
            raise NoImageError("clipboard does not contain a PNG image")

        with open(path, "rb") as handle:
            return handle.read()
    finally:
        try:
            os.remove(path)
        except FileNotFoundError:
            pass


def read_png_from_wayland():
    result = subprocess.run(
        ["wl-paste", "--no-newline", "--type", "image/png"],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if result.returncode != 0 or not result.stdout:
        raise NoImageError("clipboard does not expose image/png")
    return result.stdout


def read_png_from_x11():
    result = subprocess.run(
        ["xclip", "-selection", "clipboard", "-t", "image/png", "-o"],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if result.returncode != 0 or not result.stdout:
        raise NoImageError("clipboard does not expose image/png")
    return result.stdout


def get_png_bytes(static_file=None):
    if static_file:
        with open(static_file, "rb") as handle:
            return handle.read()

    backend = detect_backend()
    if backend is None:
        raise ClipboardError("no supported clipboard backend found")

    if backend == "macos":
        return read_png_from_macos()
    if backend == "wayland":
        return read_png_from_wayland()
    if backend == "x11":
        return read_png_from_x11()

    raise ClipboardError(f"unsupported backend: {backend}")


def make_handler(token, static_file):
    class Handler(BaseHTTPRequestHandler):
        def do_GET(self):
            if self.path == "/health":
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                body = {
                    "status": "ok",
                    "backend": detect_backend(),
                    "static_file": static_file,
                }
                self.wfile.write(json.dumps(body).encode("utf-8"))
                return

            if self.path != "/v1/clipboard.png":
                self.send_error(404)
                return

            auth = self.headers.get("Authorization", "")
            if auth != f"Bearer {token}":
                self.send_error(401)
                return

            try:
                payload = get_png_bytes(static_file=static_file)
            except NoImageError as exc:
                self.send_response(404)
                self.send_header("Content-Type", "text/plain; charset=utf-8")
                self.end_headers()
                self.wfile.write(str(exc).encode("utf-8"))
                return
            except ClipboardError as exc:
                self.send_response(503)
                self.send_header("Content-Type", "text/plain; charset=utf-8")
                self.end_headers()
                self.wfile.write(str(exc).encode("utf-8"))
                return
            except OSError as exc:
                self.send_response(500)
                self.send_header("Content-Type", "text/plain; charset=utf-8")
                self.end_headers()
                self.wfile.write(str(exc).encode("utf-8"))
                return

            self.send_response(200)
            self.send_header("Content-Type", "image/png")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)

        def log_message(self, _fmt, *_args):
            return

    return Handler


def parse_args():
    parser = argparse.ArgumentParser(description="xcv clipboard daemon")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=18339)
    parser.add_argument("--token")
    parser.add_argument("--static-file")
    parser.add_argument("--print-backend", action="store_true")
    return parser.parse_args()


def main():
    args = parse_args()

    if args.print_backend:
        backend = detect_backend()
        if backend is None:
            print("unavailable", file=sys.stderr)
            return 1
        print(backend)
        return 0

    if not args.token:
        print("--token is required", file=sys.stderr)
        return 1

    server = ThreadingHTTPServer((args.host, args.port), make_handler(args.token, args.static_file))
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
